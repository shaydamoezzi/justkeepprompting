    "device_map": "auto",
    "temperature": 0.2,
    "max_new_tokens": 192,
    "attn_implementation": "sdpa",
    "trust_remote_code": true
  },
  "auxiliary": {
    "enabled": false,
    "kind": "heuristic"
  }
